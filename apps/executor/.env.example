# ─────────────────────────────────────────────────────────────────────────────
# VouchFX — Executor worker environment template (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─── (same project as web app) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ─── (console.anthropic.com → API Keys) ─────────────────────────
# Required — executor calls Claude to parse every signal.
ANTHROPIC_API_KEY=

# ── MetaApi ─── (app.metaapi.cloud → API access → Auth token) ────────────────
# Required — executor places/cancels/closes trades via MetaApi.
METAAPI_TOKEN=

# ── JBlanked News API ─── (jblanked.com/news/api → API key) ──────────────────
# Economic-calendar primary feed. FREE TIER: 1 request/day (enforced in code).
JBLANKED_API_KEY=

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: rediss://:<token>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ── Encryption ── (same 32-byte base64 key as web app) ───────────────────────
ENCRYPTION_KEY=

# ── Resend (optional) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
ADMIN_EMAILS=
