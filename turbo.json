{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_APP_URL",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "ENCRYPTION_KEY",
    "ANTHROPIC_API_KEY",
    "METAAPI_TOKEN",
    "SPIKE_METAAPI_ACCOUNT_ID",
    "TELEGRAM_API_ID",
    "TELEGRAM_API_HASH",
    "TELEGRAM_SESSION_STRING",
    "TELEGRAM_SPIKE_CHAT_ID",
    "REDIS_URL",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PRICE_STARTER_ID",
    "STRIPE_PRICE_PRO_ID",
    "STRIPE_PRICE_FUNDED_ID",
    "STRIPE_PRICE_LIFETIME_ID",
    "PAYSTACK_SECRET_KEY",
    "PAYSTACK_WEBHOOK_SECRET",
    "PAYSTACK_PLAN_STARTER_CODE",
    "PAYSTACK_PLAN_PRO_CODE",
    "PAYSTACK_PLAN_FUNDED_CODE",
    "PAYSTACK_LIFETIME_AMOUNT_KOBO",
    "RESEND_API_KEY",
    "JBLANKED_API_KEY",
    "SENTRY_DSN",
    "ADMIN_EMAILS",
    "VAPID_PUBLIC_KEY",
    "VAPID_PRIVATE_KEY",
    "VAPID_SUBJECT",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
