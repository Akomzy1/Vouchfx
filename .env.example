# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Telegram listener ─────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session string — run `pnpm --filter @vouchfx/listener exec tsx src/auth.ts` once to generate
TELEGRAM_SESSION_STRING=
# Phase-0 spike: channel chat id (e.g. -1001234567890). Visible in channel URLs or via @username_to_id_bot
TELEGRAM_SPIKE_CHAT_ID=

# ── Anthropic (signal parser) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── MetaApi (broker execution) ────────────────────────────
METAAPI_TOKEN=
# Phase-0 spike: MetaApi account id for the hardcoded demo account (from app.metaapi.cloud)
SPIKE_METAAPI_ACCOUNT_ID=
# Set to "true" to actually place the spike trade (requires DEMO account)
SPIKE_EXECUTE_TRADE=false

# ── Redis (BullMQ queue — ioredis-compatible TCP URL) ─────
# Local dev:  redis://localhost:6379
# Upstash:    rediss://:<token>@<host>:6380  (get from Upstash console → Redis → Connect → ioredis)
REDIS_URL=redis://localhost:6379
# Legacy Upstash REST keys (not used by BullMQ — kept for reference)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Encryption (session strings at rest, 32-byte base64) ──
ENCRYPTION_KEY=

# ── Resend (transactional email) ──────────────────────────
RESEND_API_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Paystack (Nigeria) ────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ── Next.js public (prefix required) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# App URL (used for OAuth redirects + email links in P1.3+)
NEXT_PUBLIC_APP_URL=http://localhost:3000
